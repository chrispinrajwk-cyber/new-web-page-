<!DOCTYPE html>
<html>
<head>
    <title>My JavaScript Page</title>
    <style>
        body {
            text-align: center;
            font-family: Arial;
            margin-top: 50px;
        }
        button {
            padding: 10px 20px;
            font-size: 16px;
        }
    </style>
</head>
<body>

    <h1>🚀 JavaScript Demo Page</h1>
    <p id="text">Click the button to change this text</p>

    <button onclick="changeText()">Click Me</button>

    <script>
        function changeText() {
            document.getElementById("text").innerHTML = "Hello DevOps Learner 🎉";
        }
    </script>

</body>
</html>
